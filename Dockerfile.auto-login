# 多阶段构建 - 支持自动登录的完整镜像
FROM golang:1.26 AS builder

WORKDIR /build
COPY . .

# 构建
RUN go mod download && \
    go build -o enscan .

# 运行时镜像
FROM debian:bookworm-slim

# 安装 Chromium 和必要依赖
RUN apt-get update && apt-get install -y \
    chromium \
    chromium-driver \
    ca-certificates \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libatspi2.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libwayland-client0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxkbcommon0 \
    libxrandr2 \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*

# 设置 Chrome 环境变量
ENV CHROME_BIN=/usr/bin/chromium \
    CHROME_PATH=/usr/lib/chromium/

# 复制编译好的二进制
COPY --from=builder /build/enscan /app/enscan

WORKDIR /app

# 创建配置目录
RUN mkdir -p /root/.claude

ENTRYPOINT ["/app/enscan"]
CMD ["--help"]
